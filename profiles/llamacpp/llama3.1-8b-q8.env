# Profile: Meta-Llama-3.1-8B-Instruct (Q8_0)
# 타겟 하드웨어: RTX 4080 16GB (전체 VRAM 활용)
# 8B dense 모델 Q8_0 (~8.5GB) → 전체가 VRAM 에 올라감, expert offload 불필요.

CONTAINER_NAME=llama3.1-8b
LLAMA_PORT=8080
CONFIG_NAME=llama3.1-8b-q8
GPU_ID=0

MODEL_FILE=Meta-Llama-3.1-8B-Instruct-Q8_0.gguf
HF_REPO=bartowski/Meta-Llama-3.1-8B-Instruct-GGUF
HF_FILE=Meta-Llama-3.1-8B-Instruct-Q8_0.gguf
