# 프로필 템플릿 — 새 프로필 작성 시 복사해서 사용.
# ─────────────────────────────────────────────────────────────
# cp profiles/example.env profiles/<your-profile>.env

# Docker container 이름 (프로필마다 고유)
CONTAINER_NAME=my-model

# 호스트 노출 포트 (동시 운영 시 충돌 주의)
LLAMA_PORT=8080

# config/<CONFIG_NAME>.yaml 파일명 (확장자 제외).
# 비워두면 프로필 이름과 동일하게 간주.
CONFIG_NAME=my-model

# GPU 장치 ID (숫자 또는 'all'). 다중 GPU 환경에서 사용 장치 선택.
GPU_ID=0

# ─── 모델 다운로드 (scripts/pull-model.sh) ───
# GGUF 파일명 (models/ 아래 저장됨)
MODEL_FILE=your-model.gguf

# HuggingFace 저장소 & 파일명 (`hf download` 인자)
HF_REPO=unsloth/Some-Model-GGUF
HF_FILE=your-model.gguf
