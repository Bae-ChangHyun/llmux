# Profile: NewModel
# GPU: 0, Port: 8002, Model: new-model-name

CONTAINER_NAME=newmodel
VLLM_PORT=8002
CONFIG_NAME=new-model-config

# GPU Configuration
GPU_ID=0
TENSOR_PARALLEL_SIZE=1

# Extra Pip Packages (optional)
# Install additional pip packages before starting vllm serve
# Prefer pinned package versions over mutable archive URLs
#EXTRA_PIP_PACKAGES=flash-attn==2.7.4.post1

# Container Environment Variables (optional)
# Any variables added here are automatically injected into the container
#VLLM_USE_FLASHINFER_MOE_MXFP4_MXFP8=1

# LoRA Configuration (optional)
ENABLE_LORA=false
#MAX_LORAS=2
#MAX_LORA_RANK=16
#LORA_MODULES=adapter1=/app/lora/path1
