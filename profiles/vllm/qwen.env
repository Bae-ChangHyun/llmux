# Profile: VLM (Vision Language Model)
# GPU: 0, Port: 8000, Model: Qwen3-VL-30B

CONTAINER_NAME=vlm
VLLM_PORT=8000
CONFIG_NAME=qwen3-vl-30b-a3b-fp8

# GPU Configuration
GPU_ID=0
TENSOR_PARALLEL_SIZE=1

# LoRA Configuration (optional)
# Set ENABLE_LORA=true to enable LoRA support
ENABLE_LORA=false
MAX_LORAS=2
MAX_LORA_RANK=16
# Format: name1=/app/lora/path1,name2=/app/lora/path2
# Paths are relative to LORA_BASE_PATH mounted at /app/lora
#LORA_MODULES=ocr-li=/app/lora/qwen3vl_li/lora_model,ocr-jk=/app/lora/qwen3vl_jk/lora_model
