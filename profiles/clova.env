# Profile: CLOVA (HyperCLOVA)
# GPU: 1, Port: 8000, Model: HyperCLOVAX-SEED-Think-32B

CONTAINER_NAME=clova
VLLM_PORT=8000
CONFIG_NAME=hyperclova-seed-think-32b

# GPU Configuration
GPU_ID=1
TENSOR_PARALLEL_SIZE=1

# LoRA Configuration (optional)
# Set ENABLE_LORA=true to enable LoRA support
ENABLE_LORA=false
#MAX_LORAS=2
#MAX_LORA_RANK=16
#LORA_MODULES=adapter1=/app/lora/path1
