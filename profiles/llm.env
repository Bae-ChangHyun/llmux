# Profile: LLM (Large Language Model)
# GPU: 1, Port: 8001, Model: GPT-OSS-120B

CONTAINER_NAME=llm
VLLM_PORT=8001
CONFIG_NAME=gpt-oss-120b

# GPU Configuration
GPU_ID=1
TENSOR_PARALLEL_SIZE=1

# LoRA Configuration (optional)
# Set ENABLE_LORA=true to enable LoRA support
ENABLE_LORA=false
#MAX_LORAS=2
#MAX_LORA_RANK=16
#LORA_MODULES=adapter1=/app/lora/path1
