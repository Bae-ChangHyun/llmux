/* vLLM Compose TUI — Minimal Theme */

/* ── Base ─────────────────────────────────────────────────────── */
Screen {
    background: $surface;
}

/* ── Dashboard ────────────────────────────────────────────────── */
DashboardScreen {
    layout: vertical;
}

#dashboard-header {
    height: auto;
    padding: 1 2 0 2;
}

#dashboard-brand {
    text-style: bold;
    color: $primary;
    width: 100%;
    text-align: center;
}

#dashboard-subtitle {
    color: $text-muted;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#status-bar {
    height: 1;
    padding: 0 2;
    color: $text-muted;
    margin-bottom: 0;
}

#profile-table {
    height: 1fr;
    margin: 0 2 1 2;
    border: round $primary 40%;
}

/* ── Empty State ──────────────────────────────────────────────── */
#empty-state {
    height: 1fr;
    margin: 0 2 1 2;
    border: round $primary 40%;
    content-align: center middle;
    text-align: center;
    color: $text-muted;
}

/* ── Log Screen ───────────────────────────────────────────────── */
#log-view {
    height: 1fr;
    margin: 0 1 1 1;
    border: round $primary 40%;
}

/* ── Modal Screens ────────────────────────────────────────────── */
ModalScreen {
    align: center middle;
}

ModalScreen > Vertical {
    background: $surface;
    border: round $primary;
    padding: 1 2;
    width: 65;
    max-height: 80%;
}

/* ── Forms ─────────────────────────────────────────────────────── */
.form-container {
    padding: 1 2;
    height: auto;
    max-height: 80%;
    width: 65;
    align: center middle;
}

.form-container Input {
    margin-bottom: 1;
}

.form-container Select {
    margin-bottom: 1;
}

.form-container Label {
    margin-bottom: 0;
    color: $text-muted;
}

.form-row {
    height: auto;
    margin-bottom: 1;
}

.form-row Label {
    width: 22;
    padding: 1 1 0 0;
    color: $text-muted;
}

.form-buttons {
    layout: horizontal;
    height: 1;
    align: center middle;
    margin-top: 1;
}

.form-buttons Button {
    margin: 0 1;
    min-width: 14;
    height: 1;
    border: none;
    background: $primary;
    color: $text;
    text-style: bold;
}

.form-buttons Button:hover {
    background: $primary-lighten-1;
}

.form-buttons Button.-error-variant {
    background: $error;
}

.form-buttons Button.-default-variant {
    background: $surface-lighten-1;
}

/* Generic .buttons (used in modals) */
.buttons {
    layout: horizontal;
    height: 1;
    align: center middle;
    margin-top: 1;
}

.buttons Button {
    margin: 0 1;
    min-width: 14;
    height: 1;
    border: none;
    background: $primary;
    color: $text;
    text-style: bold;
}

.buttons Button:hover {
    background: $primary-lighten-1;
}

.buttons Button.-error-variant {
    background: $error;
}

.buttons Button.-default-variant {
    background: $surface-lighten-1;
}

/* ── Config / System sub-screens ─────────────────────────────── */
#config-title {
    padding: 1 2;
    text-style: bold;
    color: $primary;
}

#config-table {
    height: 1fr;
    margin: 0 2 1 2;
    border: round $primary 40%;
}

.section-title {
    margin: 1 2 0 2;
    text-style: bold;
    color: $primary;
}

#gpu-table {
    height: auto;
    max-height: 14;
    margin: 0 2;
    border: round $primary 40%;
}

#official-images,
#dev-images {
    height: auto;
    max-height: 10;
    margin: 0 2;
    border: round $primary 40%;
}

/* ── TabbedContent ────────────────────────────────────────────── */
TabbedContent {
    height: 1fr;
}

ContentSwitcher {
    height: 1fr;
}

TabPane {
    padding: 1 0;
}
