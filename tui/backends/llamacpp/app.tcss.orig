/* llama.cpp Compose TUI styles */

Screen {
    layout: vertical;
}

#profile-table {
    height: 1fr;
    border: round $primary;
}

#gpu-bar {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $text;
    border-top: solid $primary 40%;
}

#status-bar {
    height: 3;
    padding: 0 1;
    background: $surface;
    border-top: solid $primary;
}

#status-bar Static {
    width: 1fr;
}

LogViewer {
    align: center middle;
}

#log-container {
    width: 90%;
    height: 85%;
    border: round $primary;
    background: $surface;
}

#log-title {
    dock: top;
    height: 1;
    background: $primary;
    color: $text;
    padding: 0 1;
    text-style: bold;
}

#log-body {
    height: 1fr;
    padding: 0 1;
    background: $surface;
    scrollbar-gutter: stable;
}

ActionModal {
    align: center middle;
}

#action-dialog {
    width: 42;
    height: auto;
    max-height: 90%;
    border: round $primary 60%;
    background: $surface;
    padding: 1 2;
}

#action-dialog > Label {
    margin-bottom: 0;
    width: 100%;
    content-align: left middle;
}

#action-dialog .action-rule {
    height: 1;
    width: 100%;
    color: $primary 40%;
    margin: 0;
}

#action-dialog .action-section {
    margin-top: 1;
    height: 1;
}

#action-dialog .action-foot {
    margin-top: 0;
    height: 1;
    content-align: right middle;
    width: 100%;
}

/* Flat button + clear focus ring inside ActionModal */
#action-dialog Button.act {
    width: 100%;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 0 0 2;      /* 왼쪽에 focus 막대 공간 확보 */
    border: none;
    background: transparent;
    color: $text;
    text-style: none;
    content-align: left middle;
}
#action-dialog Button.act:hover {
    background: $boost;
}
#action-dialog Button.act:focus {
    background: $accent 25%;
    text-style: bold;
    /* 좌측에 두꺼운 accent 막대로 현재 focus 명시 */
    border-left: outer $accent;
    padding: 0 0 0 1;
}
#action-dialog Button.act.primary {
    color: $success;
}
#action-dialog Button.act.danger {
    color: $error;
}
#action-dialog Button.act:disabled {
    color: $text-muted 60%;
    background: transparent;
    text-style: none;
}

.running {
    color: $success;
    text-style: bold;
}

.stopped {
    color: $text-muted;
}

.current {
    text-style: bold;
    color: $accent;
}

.missing {
    color: $warning;
}
