# Common Configuration
# This file contains shared settings for all profiles
# Copy this file to .env.common and fill in your values

# vLLM Image Version
# Options: latest, nightly, or specific version (e.g., v0.15.0)
# Check releases: https://github.com/vllm-project/vllm/releases
VLLM_VERSION=latest

# Hugging Face Configuration
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HF_CACHE_PATH=~/.cache/huggingface

# LoRA Configuration
# Base path for LoRA adapters (mounted to /app/lora in container)
# Leave empty if not using LoRA
LORA_BASE_PATH=/path/to/your/lora/adapters
